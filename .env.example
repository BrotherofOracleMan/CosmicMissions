# Copy to .env and fill in your local values:
#   cp .env.example .env

# Local / CI (password auth)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/cosmic_missions_db
TEST_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/cosmic_missions_test_db
API_KEY=your-api-key-here

# Azure App Service only (Managed Identity path — leave DATABASE_URL unset there):
# DBHOST=rg-cosmic-missions-database.postgres.database.azure.com
# DBNAME=cosmic_missions_db
# DBUSER=rg-cosmic-missions
